# ============================================
# 環境変数テンプレート
# このファイルを .env.local にコピーして値を記入してください
# cp .env.example .env.local
# ============================================

# --- Notion ---
NOTION_API_KEY=
NOTION_DATABASE_ID=

# --- Discord ---
DISCORD_WEBHOOK_URL=

# --- Cloudflare R2 ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=yosuke-kiddy
R2_PUBLIC_URL=

# --- Google Maps (Embed API + Places Autocomplete 共用) ---
# Maps Embed API と Places API (New) を両方有効化すること
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Admin ---
ADMIN_PASSWORD=

# --- LINE (送信後表示用) ---
NEXT_PUBLIC_LINE_ADD_FRIEND_URL=
NEXT_PUBLIC_LINE_QR_IMAGE_PATH=

# --- OGP / Site ---
NEXT_PUBLIC_SITE_URL=https://yosuke-kiddy.com

# --- Form Control ---
# 告別式後にフォームを閉じる場合は true に設定
# NEXT_PUBLIC_FORM_CLOSED=false
